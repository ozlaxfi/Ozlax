{
  "name": "ozlax",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "app"
  ],
  "scripts": {
    "build": "npm run build:app",
    "test:anchor": "anchor test --provider.cluster localnet",
    "build:anchor": "anchor build",
    "build:app": "npm run build --workspace @ozlax/app",
    "vercel-build": "npm run build --workspace @ozlax/app",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace @ozlax/app",
    "keeper": "ts-node keeper/bot.ts",
    "initialize:vault": "ts-node scripts/initialize-vault.ts",
    "verify:deploy": "ts-node scripts/verify-deploy.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@jito-foundation/restaking-sdk": "^1.0.0",
    "@marinade.finance/marinade-ts-sdk": "^5.0.15",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.0",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "mocha": "^11.1.0",
    "ts-mocha": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
