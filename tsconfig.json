{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "mocha"],
    "baseUrl": "."
  },
  "include": ["tests/**/*.ts", "keeper/**/*.ts", "scripts/**/*.ts", "migrations/**/*.ts"]
}
